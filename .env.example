# ── Servidor ───────────────────────────────────────────────────
NODE_ENV=production
CAMOFOX_PORT=9377

# ── Autenticação (defina sempre em produção) ───────────────────
# Chave de acesso geral — obrigatória para proteger a API pública
CAMOFOX_ACCESS_KEY=troque-por-uma-chave-segura
# Chave admin (rotas de gestão interna)
# CAMOFOX_ADMIN_KEY=

# ── Limites de recursos ────────────────────────────────────────
MAX_OLD_SPACE_SIZE=256
MAX_SESSIONS=10
MAX_TABS_GLOBAL=20
SESSION_TIMEOUT_MS=600000
TAB_INACTIVITY_MS=300000

# ── Monitoramento ──────────────────────────────────────────────
PROMETHEUS_ENABLED=1

# ── Proxy (opcional) ──────────────────────────────────────────
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USERNAME=
# PROXY_PASSWORD=
